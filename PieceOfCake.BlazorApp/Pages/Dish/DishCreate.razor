@page "/dishes/create"
@inherits DishCreateBase

<h1>Create Dish</h1>
<EditForm Model="Item" OnValidSubmit="@HandleValidSubmit">

    <div class="form-group">
        <label for="lastName">Name: </label>
        <InputText id="lastName" class="form-control" @bind-Value="@Item.Name" placeholder="Enter dish name"></InputText>
    </div>

    <div class="form-group">
        <label for="lastName">Description: </label>
        <textarea id="lastName" class="form-control" @bind="@Item.Description" placeholder="Enter dish name"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</EditForm>
<DisplayErrors Errors="Errors.ToList()">

</DisplayErrors>
