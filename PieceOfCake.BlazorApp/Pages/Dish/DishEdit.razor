@page "/edit/{Id:long}"
@inherits DishEditBase

<h1>Edit Dish</h1>
<EditForm Model="Dish" OnValidSubmit="@HandleValidSubmit">

    <div class="form-group">
        <label for="name">Name: </label>
        <InputText id="name" class="form-control" @bind-Value="@Dish.Name" placeholder="Enter dish name"></InputText>
    </div>

    <div class="form-group">
        <label for="description">Description: </label>
        <textarea id="description" class="form-control" @bind="@Dish.Description" placeholder="Enter dish description"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</EditForm>
<DisplayErrors Errors="Errors.ToList()">

</DisplayErrors>
